{
  "description": "Parses a Splunk HEC JSON envelope into splunk.* fields. Can be called from any per-sourcetype pipeline via a pipeline processor so the parsing logic lives in one place.",
  "processors": [
    {
      "set": {
        "tag": "set_ecs_version",
        "field": "ecs.version",
        "value": "9.3.0"
      }
    },
    {
      "json": {
        "tag": "json_parse_splunk_envelope",
        "field": "message",
        "target_field": "splunk"
      }
    },
    {
      "set": {
        "tag": "set_event_original",
        "field": "event.original",
        "copy_from": "splunk.event",
        "ignore_empty_value": true,
        "ignore_failure": true
      }
    },
    {
      "date": {
        "tag": "set_timestamp",
        "field": "splunk.time",
        "target_field": "@timestamp",
        "formats": ["UNIX"],
        "if": "ctx.splunk?.time != null"
      }
    },
    {
      "remove": {
        "tag": "remove_splunk_envelope",
        "field": "message",
        "ignore_missing": true
      }
    },
    {
      "rename": {
        "tag": "promote_event_to_message",
        "field": "splunk.event",
        "target_field": "message",
        "ignore_missing": true
      }
    },
    {
      "script": {
        "tag": "calc_event_bytes",
        "lang": "painless",
        "if": "ctx.message != null",
        "source": "ctx['splunk']['bytes'] = ctx['message'].length();"
      }
    }
  ],
  "on_failure": [
    {
      "set": {
        "field": "event.kind",
        "value": "pipeline_error"
      }
    },
    {
      "append": {
        "field": "error.message",
        "value": "Processor '{{{ _ingest.on_failure_processor_type }}}' with tag '{{{ _ingest.on_failure_processor_tag }}}' in pipeline '{{{ _ingest.pipeline }}}' failed with message '{{{ _ingest.on_failure_message }}}'"
      }
    },
    {
      "append": {
        "field": "tags",
        "value": "preserve_original_event",
        "allow_duplicates": false
      }
    }
  ]
}
